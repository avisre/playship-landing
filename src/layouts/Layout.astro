---
import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/500.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/500.css";
import "../styles/global.css";
import StructuredData from "../components/StructuredData.astro";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PlayShip — Google Play submission service",
  description = "Submission, policy compliance, and rejection recovery for React Native, Expo, and Android apps. Live in 7 days, or your money back.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og-image.png", Astro.site).toString();
const keywords =
  "google play submission, play store rejection recovery, android app submission service, expo react native play store, data safety form, play console help";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="PlayShip UK" />
    <meta name="robots" content="index,follow" />
    <meta name="googlebot" content="index,follow" />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <meta name="theme-color" content="#FAFAF7" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PlayShip" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="PlayShip — Google Play submission service" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="PlayShip — Google Play submission service" />

    <!-- Search engine verification placeholders.
         Swap the content value with the real token from each console.
         See SEO_CHANGES.md for the exact swap steps. -->
    <meta name="google-site-verification" content="GOOGLE_VERIFICATION_PLACEHOLDER" />
    <meta name="msvalidate.01" content="BING_VERIFICATION_PLACEHOLDER" />

    <StructuredData />

    <!-- Google Analytics 4 (gtag.js). GA4 property "PlayShip", web stream
         playship.pro. Account + IDs documented in ANALYTICS.md (gitignored). -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-7V3EV37QM3"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-7V3EV37QM3");
    </script>

    <!-- Microsoft Clarity — heatmaps, session recordings, usage analytics.
         Clarity project "PlayShip" (id wyg1vuuhxj). See ANALYTICS.md. -->
    <script is:inline>
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "wyg1vuuhxj");
    </script>
  </head>
  <body>
    <Header />
    <slot />

    <!-- GA4 custom-event wiring for CTA buttons. Fires a `cta_click` event with
         the CTA id/label whenever an element carrying data-ga-event is clicked.
         ~350 bytes, no dependencies. -->
    <script is:inline>
      (function () {
        document.addEventListener("click", function (e) {
          var t = e.target;
          while (t && t !== document) {
            if (t.hasAttribute && t.hasAttribute("data-ga-event")) {
              if (typeof window.gtag === "function") {
                var id = t.getAttribute("data-ga-event");
                window.gtag("event", "cta_click", {
                  cta_id: id,
                  cta_label: t.getAttribute("data-ga-label") || id,
                });
              }
              return;
            }
            t = t.parentNode;
          }
        });
      })();
    </script>
  </body>
</html>
