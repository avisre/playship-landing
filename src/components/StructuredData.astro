---
const site = "https://playship.pro";

const service = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${site}/#service`,
  name: "PlayShip",
  description:
    "Google Play submission, policy compliance, and rejection recovery for React Native, Expo, and Android apps. Live in 7 days, or full refund on the Express tier.",
  serviceType: "Google Play Store submission",
  url: site,
  image: `${site}/og-image.png`,
  brand: { "@type": "Brand", name: "PlayShip UK" },
  provider: {
    "@type": "Person",
    "@id": `${site}/#avinash`,
    name: "Avinash Sreekumar",
    jobTitle: "Mobile app developer and Play Store submission specialist",
    url: site,
    email: "support@stockportfolio.pro",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Camberley",
      addressRegion: "Surrey",
      postalCode: "GU17 9EZ",
      addressCountry: "GB",
    },
  },
  areaServed: [
    { "@type": "Country", name: "United Kingdom" },
    { "@type": "Place", name: "Worldwide" },
  ],
  audience: {
    "@type": "Audience",
    audienceType: "Indie developers, startups, and React Native / Expo teams shipping Android apps",
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "PlayShip submission tiers",
    itemListElement: [
      {
        "@type": "Offer",
        name: "Express",
        description: "You have a working AAB. We submit it. Turnaround 2–3 days.",
        price: "149",
        priceCurrency: "GBP",
        url: `${site}/#pricing`,
        availability: "https://schema.org/InStock",
        category: "Submission",
      },
      {
        "@type": "Offer",
        name: "Full launch",
        description:
          "ASO-tuned store listing copy, designed screenshots, privacy policy, closed testing to production. Turnaround 5–7 days.",
        price: "399",
        priceCurrency: "USD",
        url: `${site}/#pricing`,
        availability: "https://schema.org/InStock",
        category: "Submission",
      },
      {
        "@type": "Offer",
        name: "Rescue & relaunch",
        description:
          "Full policy audit, violation-specific fixes, Google Support escalation, 60-day post-launch support. Turnaround 7–14 days.",
        price: "799",
        priceCurrency: "USD",
        url: `${site}/#pricing`,
        availability: "https://schema.org/InStock",
        category: "Rejection recovery",
      },
    ],
  },
};

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${site}/#localbusiness`,
  name: "PlayShip UK",
  description:
    "Google Play submission and rejection recovery service operated by Avinash Sreekumar from Camberley, United Kingdom. UK sole trader.",
  url: site,
  image: `${site}/og-image.png`,
  email: "support@stockportfolio.pro",
  priceRange: "£149–$799",
  founder: { "@id": `${site}/#avinash` },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Camberley",
    addressRegion: "Surrey",
    postalCode: "GU17 9EZ",
    addressCountry: "GB",
  },
  areaServed: [
    { "@type": "Country", name: "United Kingdom" },
    { "@type": "Place", name: "Worldwide" },
  ],
};

const faqs = [
  {
    q: "Can you guarantee Google approves my app?",
    a: "No — Google's review is opaque. I guarantee compliant submission. If they reject for something I missed (Data Safety, content rating, etc.), I fix it free. If they reject for a fundamental policy issue with the app itself (gambling without licensing, scraping, etc.), I'll tell you that upfront before we start.",
  },
  {
    q: "What if my app gets rejected after you submit?",
    a: "Express tier includes 1 free revision. Full launch includes 2. If it's a policy issue I should have caught, I keep iterating at no extra cost until it lands.",
  },
  {
    q: "Do I need to give you my Play Console password?",
    a: "No. You add me as a release manager on your Play Console with limited permissions. I never need your password.",
  },
  {
    q: "How fast can you start?",
    a: "Same day if I have capacity. I usually have 1–2 slots open per week. Reply via the form and I'll respond within 12 hours.",
  },
  {
    q: "Do you handle iOS App Store too?",
    a: "Not yet — Android only. Apple is a different beast and I won't pretend expertise I don't have.",
  },
  {
    q: "What apps will you decline?",
    a: "Anything that clearly violates Google Play policy: gambling without proper licensing, fake AI products, scraping or copyright violations, predatory lending without compliance certifications. I'll tell you within an hour of receiving your details if it's a no.",
  },
];

const faqPage = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${site}/#faq`,
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};

const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${site}/#website`,
  url: site,
  name: "PlayShip",
  description:
    "Google Play submission service for React Native, Expo, and Android apps.",
  publisher: { "@id": `${site}/#avinash` },
  inLanguage: "en",
};
---

<script type="application/ld+json" set:html={JSON.stringify(service)} />
<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
<script type="application/ld+json" set:html={JSON.stringify(faqPage)} />
<script type="application/ld+json" set:html={JSON.stringify(website)} />
