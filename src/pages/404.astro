---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found — PlayShip">
  <main class="container" style="padding-block: 160px; text-align: center;">
    <p class="eyebrow" style="color: var(--muted);">404</p>
    <h1 style="margin-top: 16px;">Page not found</h1>
    <p style="color: var(--muted); margin-top: 16px;">
      That route doesn't exist. <a href="/" style="color: var(--ink); border-bottom: 0.5px solid var(--line-strong);">Back to the landing page</a>.
    </p>
  </main>
</Layout>
